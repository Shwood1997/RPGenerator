<?xml version="1.0" encoding="utf-8"?>
<!-- This file describes how the main screen looks -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        tools:context=".MainActivity">

        <!-- The main title at the top of the screen -->
        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/alegreya_sc"
            android:letterSpacing=".05"
            android:paddingTop="16dp"
            android:paddingBottom="10dp"
            android:text="@string/title"
            android:textColor="@color/gold"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- The small instruction text under the title -->
        <TextView
            android:id="@+id/underTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/alegreya_sc"
            android:gravity="center"
            android:paddingBottom="15dp"
            android:text="@string/subtitle"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/appTitle" />

        <!-- The box that shows how many stat points you have spent or have left -->
        <LinearLayout
            android:id="@+id/attributePoints"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/feature_container"
            android:padding="4dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="22dp"
            app:layout_constraintTop_toBottomOf="@id/underTitle"
            app:layout_constraintStart_toEndOf="@+id/characterFrame"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent=".48">

            <TextView
                android:id="@+id/pointsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alegreya_sc"
                android:gravity="center"
                android:paddingBottom="4dp"
                android:text="@string/attributeTitle"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Shows total points used -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/allocatedPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:fontFamily="@font/alegreya_sc"
                        android:text="100"
                        android:textColor="@color/gold"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/alegreya_sc"
                        android:gravity="center"
                        android:text="@string/allocated"
                        android:textColor="@color/white"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Small gold vertical divider line -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_vertical"
                    android:background="@color/gold" />

                <!-- Shows points still available to spend -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/remainingPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:fontFamily="@font/alegreya_sc"
                        android:text="0"
                        android:textColor="@color/gold"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/alegreya_sc"
                        android:gravity="center"
                        android:text="@string/remaining"
                        android:textColor="@color/white"
                        android:textSize="10sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- The box containing all the stat sliders (Strength, Wisdom, etc.) -->
        <LinearLayout
            android:id="@+id/attributesColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/feature_container"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingBottom="12dp"
            android:paddingTop="4dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/attributePoints"
            app:layout_constraintStart_toStartOf="@id/attributePoints"
            app:layout_constraintEnd_toEndOf="@id/attributePoints">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alegreya_sc"
                android:gravity="center"
                android:paddingBottom="4dp"
                android:text="@string/attributes"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- These "include" lines load the stat slider designs from a different file -->
            <include layout="@layout/attribute_row" android:id="@+id/strengthRow" />
            <include layout="@layout/attribute_row" android:id="@+id/intRow" />
            <include layout="@layout/attribute_row" android:id="@+id/dexRow" />
            <include layout="@layout/attribute_row" android:id="@+id/wisRow" />
        </LinearLayout>

        <!-- The frame where the character portrait image is displayed -->
        <FrameLayout
            android:id="@+id/characterFrame"
            android:background="@drawable/image_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="22dp"
            app:layout_constraintWidth_percent="0.48"
            app:layout_constraintTop_toBottomOf="@id/underTitle"
            app:layout_constraintBottom_toBottomOf="@id/attributesColumn"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/characterImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/empty_character" />
        </FrameLayout>

        <!-- The box for typing in the character name -->
        <LinearLayout
            android:id="@+id/nameBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/feature_container"
            android:padding="10dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/characterFrame"
            app:layout_constraintStart_toStartOf="@id/characterFrame"
            app:layout_constraintEnd_toEndOf="@id/characterFrame">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alegreya_sc"
                android:paddingTop="0dp"
                android:paddingBottom="4dp"
                android:text="@string/characterName"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/name_field"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center_vertical|start"
                android:fontFamily="@font/alegreya_sc"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:textColorHint="@color/white"
                android:hint="@string/name_hint"
                android:autofillHints="null" />
        </LinearLayout>

        <!-- The box for picking Male or Female -->
        <LinearLayout
            android:id="@+id/genderBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/feature_container"
            android:padding="10dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/nameBox"
            app:layout_constraintStart_toStartOf="@id/nameBox"
            app:layout_constraintEnd_toEndOf="@id/nameBox">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alegreya_sc"
                android:text="@string/gender"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <RadioGroup
                android:id="@+id/genderGroup"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/genderMale"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:fontFamily="@font/alegreya_sc"
                    android:text="@string/male"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:padding="0dp"
                    android:textColor="@color/radio_text_color"
                    app:buttonTint="@color/radio_button_color" />

                <RadioButton
                    android:id="@+id/genderFemale"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:fontFamily="@font/alegreya_sc"
                    android:text="@string/female"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:padding="0dp"
                    android:textColor="@color/radio_text_color"
                    app:buttonTint="@color/radio_button_color"/>
            </RadioGroup>

        </LinearLayout>


        <!-- The box for picking a Character Class -->
        <LinearLayout
            android:id="@+id/classBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/feature_container"
            android:padding="10dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/attributesColumn"
            app:layout_constraintStart_toStartOf="@id/attributesColumn"
            app:layout_constraintEnd_toEndOf="@id/attributesColumn">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alegreya_sc"
                android:paddingBottom="4dp"
                android:text="@string/classes"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/classSpinner"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/spinner_field"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <!-- The box for picking a Race -->
        <LinearLayout
            android:id="@+id/raceBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/feature_container"
            android:padding="10dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/classBox"
            app:layout_constraintStart_toStartOf="@id/classBox"
            app:layout_constraintEnd_toEndOf="@id/classBox">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alegreya_sc"
                android:paddingBottom="4dp"
                android:text="@string/race"
                android:textColor="@color/gold"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/raceSpinner"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/spinner_field"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <!-- A special invisible line that helps buttons stay at the bottom in landscape view -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/bottomBarrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="raceBox,genderBox" />

        <!-- The section containing the Reset and Generate buttons -->
        <LinearLayout
            android:id="@+id/extraButtons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="24dp"
            android:paddingBottom="32dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            app:layout_constraintWidth_percent="0.75"
            app:layout_constraintTop_toBottomOf="@id/bottomBarrier"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- The Reset button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/resetButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Reset"
                android:layout_marginEnd="8dp"
                android:background="@drawable/button_framed"
                android:fontFamily="@font/alegreya_sc"
                android:textColor="@color/background"
                app:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:gravity="center"
                android:padding="0dp" />

            <!-- The Generate Image button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/generateButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Generate Image"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_framed"
                android:fontFamily="@font/alegreya_sc"
                android:textColor="@color/background"
                app:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:gravity="center"
                android:padding="0dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
